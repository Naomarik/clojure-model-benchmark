# Python caches and environments
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.venv/
venv/
dist/
build/

# Raw benchmark artifacts and generated snapshots
/artifacts/tests.json
/artifacts/matrix.json
/artifacts/MATRIX.md
/artifacts/repl-matrix.json
/artifacts/REPL_MATRIX.md
/artifacts/overall-matrix.json
/artifacts/OVERALL_MATRIX.md
/artifacts/runs/*
!/artifacts/runs/.gitkeep
/artifacts/repl-runs/
**/raw-runs/
**/repl-runs/
*.jsonl

# Keep only reviewed Markdown in the public results directory
/results/*
!/results/*.md

# OpenCode generated packages; retain project config and agents
/.opencode/node_modules/
/.opencode/package.json
/.opencode/package-lock.json
/.opencode/bun.lock
/.opencode/bun.lockb

# JavaScript tooling
node_modules/
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Credentials, local overrides, and logs
.env
.env.*
!.env.example
*.local
*.local.json
*.local.jsonc
opencode.local.json
*.log

# Editors and operating systems
.idea/
.vscode/
*~
.DS_Store

# Local analysis notes
scratch/
